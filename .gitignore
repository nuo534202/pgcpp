# MyToyDB .gitignore
# Standard C++/CMake project ignores.

# Build directories
build/
build-*/
out/

# IDE / editor files
.vscode/
.trae/
rules/
.idea/
*.swp
.DS_Store
AGENTS.md
# compile_commands.json is generated by CMake; can be symlinked into project root if desired.
compile_commands.json

# CMake generated artifacts
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake.in

# Compiled objects and binaries
*.o
*.a
*.so
*.dylib
mytoydb_*

# Sanitizer outputs
*.asan
*.tsan
*.ubsan
asan.log
tsan.log
ubsan.log

# Test artifacts
Testing/Temporary/
test/unit/*/gtest_*.cc
